# KinBridge API — copy to .env on the host before `npm start`.
# Never commit the filled-in .env. Never log these values.

# --- Bind ---
PORT=3000
HOST=127.0.0.1          # Cloudflare Tunnel connects over loopback; keep this bound to localhost.
NODE_ENV=production

# --- Service token (shared with Lovable's Worker secrets) ---
# Generate with: openssl rand -hex 32
KINBRIDGE_SERVICE_TOKEN=replace-me-32-bytes-hex

# --- JWT for tokens we mint (client -> relay handshake) ---
# Generate with: openssl rand -hex 32
KINBRIDGE_JWT_SECRET=replace-me-32-bytes-hex
KINBRIDGE_JWT_ISSUER=https://api.kinbridge.support
KINBRIDGE_JWT_AUDIENCE=kinbridge-client
# Short TTL — tokens bridge "click connect" -> "client handshakes relay" only.
KINBRIDGE_JWT_TTL_SECONDS=120

# --- Supabase (the Lovable-managed dashboard DB) ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_JWKS_URL=https://xxxxx.supabase.co/auth/v1/.well-known/jwks.json
# Only if Lovable decides to let us write directly. Prefer a scoped
# service JWT minted by Lovable instead; in that case leave this blank.
SUPABASE_SERVICE_ROLE_KEY=

# --- Headscale (self-hosted Tailscale control plane on Olares) ---
HEADSCALE_URL=http://127.0.0.1:8080
HEADSCALE_API_KEY=replace-me-from-headscale-CLI
# User (namespace) under which we mint per-device auth keys.
HEADSCALE_USER=kinbridge

# --- Hbbs log tail (optional; for device presence via log parsing) ---
HBBS_LOG_PATH=/var/log/kinbridge/hbbs.log

# --- Rate limits ---
RATE_LIMIT_GLOBAL_PER_MIN=600
RATE_LIMIT_AUTH_PER_MIN=20
